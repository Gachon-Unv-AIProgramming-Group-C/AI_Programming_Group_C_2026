PORT=8000

# LLM API keys (at least one required for Layer 2/3 verification)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Hugging Face token (required to download private/gated models)
HF_API_KEY=

# NLI model for Stage 1 (sentence similarity)
HF_MODEL_ID=jhgan/ko-sroberta-nli

# NLI model for Stage 2 (cross-encoder, our fine-tuned model)
HF_STAGE2_MODEL_ID=serize/klue-roberta-base-nli-stage2

# Local Python NLI server (set when running with Docker Compose)
# NLI_SERVER_URL=http://nli-server:8001
NLI_SERVER_PORT=8001

LOG_LEVEL=info
